# Application
APP_NAME=Azad.Edu
DEBUG=True
SECRET_KEY=your-secret-key-minimum-32-characters-long

# CORS — space-separated list of allowed origins (use * for local dev only)
ALLOWED_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql://azad_edu:azad_edu_password@localhost:5432/azad_edu

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cloudflare R2 Storage
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=your-bucket-name
CLOUDFLARE_R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-public-domain.com
